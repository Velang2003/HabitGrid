{
  "expo": {
    "name": "HabitGrid",
    "slug": "HabitGrid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "habitgrid",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.velang2003.HabitGrid"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withNotifeeAndroidRepo",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#802ddc"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "HabitWidget",
              "label": "HabitGrid Widget",
              "minWidth": "320dp",
              "minHeight": "220dp",
              "targetCellWidth": 4,
              "targetCellHeight": 3,
              "minResizeWidth": "180dp",
              "minResizeHeight": "150dp",
              "resizeMode": "horizontal|vertical",
              "description": "View and mark your habits directly from the home screen.",
              "previewImage": "./assets/images/icon.png",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "ChartWidget",
              "label": "HabitGrid Chart",
              "minWidth": "320dp",
              "minHeight": "220dp",
              "targetCellWidth": 4,
              "targetCellHeight": 3,
              "minResizeWidth": "180dp",
              "minResizeHeight": "150dp",
              "resizeMode": "horizontal|vertical",
              "description": "View habit statistics on your home screen.",
              "previewImage": "./assets/images/icon.png",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      "react-native-haptic-feedback",
      "@react-native-community/datetimepicker",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}